  <diagram id="pi-framework-flow" name="Pi-AI Framework Architecture">
    <mxGraphModel dx="1600" dy="1000" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1600" pageHeight="1200" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <!-- Title -->
        <mxCell id="title" value="&lt;b&gt;Pi-AI Framework — Data Flow Architecture&lt;/b&gt;" style="text;html=1;align=center;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;fontSize=20;" vertex="1" parent="1">
          <mxGeometry x="450" y="20" width="450" height="40" as="geometry" />
        </mxCell>

        <!-- ==================== Layer 1: User Code ==================== -->
        <mxCell id="user-group" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;dashed=1;arcSize=8;" vertex="1" parent="1">
          <mxGeometry x="340" y="80" width="620" height="100" as="geometry" />
        </mxCell>
        <mxCell id="user-label" value="&lt;b&gt;User Code&lt;/b&gt;" style="text;html=1;align=left;verticalAlign=top;fontSize=11;fontColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="350" y="85" width="100" height="20" as="geometry" />
        </mxCell>

        <mxCell id="stream-fn" value="&lt;b&gt;stream()&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px&quot;&gt;(model, context, options?)&lt;br&gt;→ AsyncIterable&amp;lt;StreamEvent&amp;gt;&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#6c8ebf;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="380" y="110" width="240" height="55" as="geometry" />
        </mxCell>

        <mxCell id="complete-fn" value="&lt;b&gt;complete()&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px&quot;&gt;(model, context, options?)&lt;br&gt;→ Promise&amp;lt;AssistantMessage&amp;gt;&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#6c8ebf;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="680" y="110" width="240" height="55" as="geometry" />
        </mxCell>

        <!-- ==================== Layer 2: Context (input) ==================== -->
